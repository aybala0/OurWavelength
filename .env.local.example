# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth — run: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret
NEXTAUTH_URL=http://localhost:3000

# Allowed emails (comma-separated, no spaces)
ALLOWED_EMAILS=you@gmail.com,friend1@gmail.com,friend2@gmail.com

# Vercel KV — copy from Vercel dashboard → Storage → your KV store → .env.local
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
